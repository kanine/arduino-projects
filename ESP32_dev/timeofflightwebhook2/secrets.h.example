// Copy this file to secrets.h and fill in your values.
// secrets.h is excluded from git.

#pragma once

#define WIFI_SSID     "your-network-name"
#define WIFI_PASSWORD "your-password"

#define WEBHOOK_URL   "https://example.com/api/readings"

// Value reported in the outbound JSON payload as "host".
#define DEVICE_HOST   "esp32-tof"

// Hostname shown in Arduino IDE's network ports list.
#define OTA_HOSTNAME  DEVICE_HOST

// Optional: protect OTA uploads with a password.
// Comment out to disable authentication.
#define OTA_PASSWORD  "your-ota-password"

// Optional: root CA certificate for TLS verification.
// If omitted, HTTPS requests will skip certificate verification.
// #define HTTP_CA_CERT "-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----\n"
