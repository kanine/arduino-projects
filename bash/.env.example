# Copy this file to bash/.env and fill in your local values.
# bash/.env is excluded from git.

# ── Arduino IDE sync (sync_to_ide.sh) ─────────────────────────────────────────
ARDUINO_IDE_DIR=/mnt/d/Scripts/arduino-projects

# ── ESP32 deploy (deploy.sh) ───────────────────────────────────────────────────
ESP32_FQBN=esp32:esp32:esp32
ESP32_OTA_PORT=192.168.x.x        # IP shown in 'arduino-cli board list'
ESP32_OTA_PASSWORD=               # leave empty if OTA_PASSWORD is not set in secrets.h

# ── Mega 2560 deploy (deploy.sh) ───────────────────────────────────────────────
MEGA_FQBN=arduino:avr:mega
MEGA_SERIAL_PORT=/dev/ttyUSB0
